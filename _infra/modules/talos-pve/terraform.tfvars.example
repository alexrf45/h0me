env = "dev"

talos = {
  name     = "abydos"
  endpoint = "192.168.20.120"
  vip_ip   = "192.168.20.119"
  version  = "v1.12.8"
  platform = "nocloud"
  control_plane_extensions = [
    "intel-ucode",
    "glibc",
    "iscsi-tools",
    "util-linux-tools",
    "qemu-guest-agent",
    "i915",
    "tailscale"
  ]
  worker_extensions = [
    "intel-ucode",
    "glibc",
    "iscsi-tools",
    "util-linux-tools",
    "qemu-guest-agent",
    "i915"
  ]
}

pve = {
  hosts    = ["home-0", "home-1", "home-2", "home-3", "home-4", "home-5"]
  endpoint = "192.168.20.2"
  gateway  = "192.168.20.1"
  password = "" # Set via TF_VAR_pve or .env
}

nameservers = {
  primary   = "1.1.1.1"
  secondary = "8.8.8.8"
  internal  = "192.168.20.1" 
  }

controlplane_nodes = {
  "1" = {
    node             = "home-0"
    ip               = "192.168.20.120"
    allow_scheduling = false
    storage_id       = "data"
    cores            = 2
    memory           = 8192
    disk_size        = 50
    storage_size     = 50
  }
  "2" = {
    node             = "home-1"
    ip               = "192.168.20.121"
    allow_scheduling = false
    storage_id       = "data"
    cores            = 2
    memory           = 8192
    disk_size        = 50
    storage_size     = 100
  }
  "3" = {
    node             = "home-2"
    ip               = "192.168.20.122"
    allow_scheduling = false
    storage_id       = "data"
    cores            = 2
    memory           = 8192
    disk_size        = 50
    storage_size     = 100
  }
}

worker_nodes = {
  "4" = {
    node         = "home-3"
    ip           = "192.168.20.123"
    storage_id   = "data"
    cores        = 2
    memory       = 8192
    disk_size    = 50
    storage_size = 100
  }
  "5" = {
    node         = "home-4"
    ip           = "192.168.20.124"
    storage_id   = "data"
    cores        = 2
    memory       = 8192
    disk_size    = 50
    storage_size = 100
  }
  "6" = {
    node         = "home-5"
    ip           = "192.168.20.125"
    storage_id   = "data"
    cores        = 2
    memory       = 8192
    disk_size    = 50
    storage_size = 200
  }
}

kubernetes_version = "v1.36.0"

cilium_config = {
  node_network               = "192.168.20.0/24"
  cilium_version             = "1.19.4"
  hubble_enabled             = false
  hubble_ui_enabled          = false
  relay_enabled              = false
  relay_pods_rollout         = false
  ingress_controller_enabled = true
  ingress_default_controller = true
  gateway_api_enabled        = true
  load_balancer_mode         = "shared"
  load_balancer_ip           = "192.168.20.200"
  load_balancer_start        = 200
  load_balancer_stop         = 215
}

# Export kubeconfig + talosconfig to 1Password (items: <cluster>-kubeconfig / <cluster>-talosconfig)
config_export = {
  enabled = true
}

flux_config = {
  enabled           = true
  git_url           = "ssh://git@github.com/alexrf45/th0th.git"
  cluster_path      = "clusters/abydos"
  branch            = "main"
  cluster_domain    = "cluster.local"
  sops_secret_name  = "sops-age"
  sops_age_key_name = "flux-staging.agekey"
}
